# ============================================================================

# Shodan (Optional - for IoT/exposed device search)
# Free tier: 100 queries/month
# Get your key: https://account.shodan.io/
# SHODAN_API_KEY=

# Have I Been Pwned (Optional - for breach checking)
# Paid service for API access
# Get your key: https://haveibeenpwned.com/API/Key
# HIBP_API_KEY=

# VirusTotal (Optional - for malware analysis)
# Free tier: 4 requests/minute
# Get your key: https://www.virustotal.com/gui/my-apikey
# VIRUSTOTAL_API_KEY=

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Output directory (default: /tmp/ptcenter_outputs)
# OUTPUT_DIR=/path/to/custom/output

# Command timeout in seconds (default: 300)
# COMMAND_TIMEOUT=300

# Enable/disable automatic AI analysis (default: true)
# AUTO_AI_ANALYSIS=true

# Enable/disable logging (default: true)
# SAVE_LOGS=true

# ============================================================================
# GETTING STARTED
# ============================================================================
# 
# Quick Setup (1 minute):
# 1. Visit: https://makersuite.google.com/app/apikey
# 2. Sign in with Google account
# 3. Click "Create API Key"
# 4. Copy your key and paste it above
# 5. Save this file as ".env" (without .example)
# 6. Run: python3 ptCenter.py
#
# That's it! No credit card, no payment, just free AI-powered pentesting!
#
# ============================================================================
# NOTES
# ============================================================================
# 
# 1. Keep this file secure - it contains your API key
# 2. Never commit .env to version control (add to .gitignore)
